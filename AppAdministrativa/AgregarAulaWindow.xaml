<Window x:Class="AppAdministrativa.AgregarAulaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Aula" Height="420" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#3F5C8C">
            <TextBlock Text="Aplicación Administrativa" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <Grid Grid.Row="1" Background="#678EC2">
            <TextBlock x:Name="TxtTitulo" Text="Agregar Registro a Aulas" Foreground="#1A2530" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="2" Margin="30,30,30,30">

            <!-- ID Aula: ej. "I-01", "I-12" -->
            <TextBlock Text="ID Aula" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="120" HorizontalAlignment="Left" Margin="0,0,0,20">
                <TextBox x:Name="txtNombre" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" Foreground="#4A4A4A"/>
            </Border>

            <!-- Número de piso -->
            <TextBlock Text="Número de piso" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="120" HorizontalAlignment="Left" Margin="0,0,0,40">
                <ComboBox x:Name="cmbPiso" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0" Foreground="#4A4A4A" SelectedIndex="0">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                </ComboBox>
            </Border>

            <Button Click="BtnGuardar_Click" Width="120" Height="40" BorderThickness="0" Foreground="#1A2530" FontWeight="SemiBold" HorizontalAlignment="Center" Cursor="Hand">
                <Button.Background>
                    <SolidColorBrush Color="#678EC2"/>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <TextBlock Text="Guardar"/>
            </Button>

        </StackPanel>
    </Grid>
</Window>
