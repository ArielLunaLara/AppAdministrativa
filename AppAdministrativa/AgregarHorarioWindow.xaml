<Window x:Class="AppAdministrativa.AgregarHorarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Horario" Height="750" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#3F5C8C">
            <TextBlock Text="Aplicación Administrativa" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <Grid Grid.Row="1" Background="#678EC2">
            <TextBlock x:Name="TxtTitulo" Text="Agregar Registro a Clases" Foreground="#1A2530" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="2" Margin="30,20,30,20">

            <!-- ID Clase: desplegable de Materias (id + nombre) -->
            <TextBlock Text="ID Clase (Materia)" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                <ComboBox x:Name="cmbIDClase" Background="Transparent" BorderThickness="0"
                          VerticalContentAlignment="Center" Padding="10,0"
                          IsEditable="False"/>
            </Border>

            <!-- Tipo -->
            <TextBlock Text="Tipo" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="140" HorizontalAlignment="Left" Margin="0,0,0,20">
                <ComboBox x:Name="cmbTipo" Background="Transparent" BorderThickness="0"
                 VerticalContentAlignment="Center" Padding="10,0" SelectedIndex="0">
                    <ComboBoxItem Content="LUN"/>
                    <ComboBoxItem Content="MAR"/>
                    <ComboBoxItem Content="MIE"/>
                    <ComboBoxItem Content="JUE"/>
                    <ComboBoxItem Content="VIE"/>
                    <ComboBoxItem Content="SAB"/>
                    <ComboBoxItem Content="LM-JV"/>
                    <ComboBoxItem Content="L-V"/>
                </ComboBox>
            </Border>

            <!-- Hora Inicio -->
            <TextBlock Text="Hora Inicio" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="140" HorizontalAlignment="Left" Margin="0,0,0,20">
                <ComboBox x:Name="cmbHoraInicio" Background="Transparent" BorderThickness="0"
                          VerticalContentAlignment="Center" Padding="10,0" SelectedIndex="0">
                    <ComboBoxItem Content="07:00"/>
                    <ComboBoxItem Content="08:00"/>
                    <ComboBoxItem Content="09:00"/>
                    <ComboBoxItem Content="10:00"/>
                    <ComboBoxItem Content="11:00"/>
                    <ComboBoxItem Content="12:00"/>
                    <ComboBoxItem Content="13:00"/>
                    <ComboBoxItem Content="14:00"/>
                    <ComboBoxItem Content="15:00"/>
                    <ComboBoxItem Content="16:00"/>
                    <ComboBoxItem Content="17:00"/>
                    <ComboBoxItem Content="18:00"/>
                    <ComboBoxItem Content="19:00"/>
                    <ComboBoxItem Content="20:00"/>
                </ComboBox>
            </Border>

            <!-- Hora Fin -->
            <TextBlock Text="Hora Fin" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="140" HorizontalAlignment="Left" Margin="0,0,0,20">
                <ComboBox x:Name="cmbHoraFin" Background="Transparent" BorderThickness="0"
                          VerticalContentAlignment="Center" Padding="10,0" SelectedIndex="1">
                    <ComboBoxItem Content="07:00"/>
                    <ComboBoxItem Content="08:00"/>
                    <ComboBoxItem Content="09:00"/>
                    <ComboBoxItem Content="10:00"/>
                    <ComboBoxItem Content="11:00"/>
                    <ComboBoxItem Content="12:00"/>
                    <ComboBoxItem Content="13:00"/>
                    <ComboBoxItem Content="14:00"/>
                    <ComboBoxItem Content="15:00"/>
                    <ComboBoxItem Content="16:00"/>
                    <ComboBoxItem Content="17:00"/>
                    <ComboBoxItem Content="18:00"/>
                    <ComboBoxItem Content="19:00"/>
                    <ComboBoxItem Content="20:00"/>
                    <ComboBoxItem Content="21:00"/>
                </ComboBox>
            </Border>

            <!-- ID Profesor: desplegable de Profesores (id - nombre) -->
            <TextBlock Text="Profesor" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" HorizontalAlignment="Stretch" Margin="0,0,0,20">
                <ComboBox x:Name="cmbIDProfesor" Background="Transparent" BorderThickness="0"
                          VerticalContentAlignment="Center" Padding="10,0"
                          IsEditable="False"/>
            </Border>

            <!-- ID Aula: desplegable de Aulas -->
            <TextBlock Text="ID Aula" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="120" HorizontalAlignment="Left" Margin="0,0,0,30">
                <ComboBox x:Name="cmbIDAula" Background="Transparent" BorderThickness="0"
                          VerticalContentAlignment="Center" Padding="10,0"
                          IsEditable="False"/>
            </Border>

            <Button Click="BtnGuardar_Click" Width="120" Height="40" BorderThickness="0"
                    Foreground="#1A2530" FontWeight="SemiBold" HorizontalAlignment="Center" Cursor="Hand">
                <Button.Background>
                    <SolidColorBrush Color="#678EC2"/>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <TextBlock Text="Guardar"/>
            </Button>

        </StackPanel>
    </Grid>
</Window>