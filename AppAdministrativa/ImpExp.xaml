<Page x:Class="AppAdministrativa.ImpExp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Importacion/Exportacion">

    <Grid Background="#F0F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="40,20,40,20">

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="Importar / Exportar Horarios"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,30"
                           Foreground="#3F5C8C"
                           HorizontalAlignment="Center"/>

                <!-- IMPORTAR -->
                <Button Click="BtnImportar_Click"
                        Width="250" Height="50"
                        Margin="0,0,0,20"
                        Background="#678EC2"
                        Foreground="White"
                        BorderThickness="0">
                    <TextBlock Text="Importar Excel"/>
                </Button>

                <!-- EXPORTAR -->
                <Button Click="BtnExportar_Click"
                        Width="250" Height="50"
                        Background="#3F5C8C"
                        Foreground="White"
                        BorderThickness="0">
                    <TextBlock Text="Exportar Excel"/>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Page>
