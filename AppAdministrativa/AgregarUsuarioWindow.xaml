<Window x:Class="AppAdministrativa.AgregarUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Usuario"
        Height="380" Width="320"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#3F5C8C">
            <TextBlock Text="Aplicación Administrativa" Foreground="White"
                       FontSize="16" VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <Grid Grid.Row="1" Background="#678EC2">
            <TextBlock x:Name="TxtTitulo" Text="Agregar Usuario"
                       Foreground="#1A2530" FontWeight="SemiBold" FontSize="14"
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </Grid>

        <StackPanel Grid.Row="2" Margin="25,20,25,0">

            <TextBlock Text="Usuario" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Margin="0,0,0,15">
                <TextBox x:Name="txtNombre" Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" Padding="10,0" Foreground="#4A4A4A"/>
            </Border>

            <TextBlock Text="Contraseña" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Margin="0,0,0,15">
                <!-- PasswordBox para que no se vea al escribir -->
                <PasswordBox x:Name="txtPassword" Background="Transparent" BorderThickness="0"
                             VerticalContentAlignment="Center" Padding="10,0"/>
            </Border>

            <TextBlock Text="Rol" FontSize="11" Foreground="#1A2530" Margin="0,0,0,5"/>
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Margin="0,0,0,0">
                <ComboBox x:Name="CmbRol" Background="Transparent" BorderThickness="0"
                          VerticalContentAlignment="Center" Padding="8,0"
                          SelectedIndex="0">
                    <ComboBoxItem Content="normal"/>
                    <ComboBoxItem Content="super"/>
                </ComboBox>
            </Border>

        </StackPanel>

        <Button Grid.Row="3" Click="BtnGuardar_Click" Width="130" Height="38"
                BorderThickness="0" Foreground="White" FontWeight="SemiBold"
                HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand">
            <Button.Background>
                <SolidColorBrush Color="#678EC2"/>
            </Button.Background>
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Button.Resources>
            <TextBlock x:Name="TxtBoton" Text="Guardar"/>
        </Button>
    </Grid>
</Window>
