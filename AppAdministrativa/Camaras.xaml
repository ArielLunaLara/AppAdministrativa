<Page x:Class="AppAdministrativa.Camaras"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Cámaras">

    <Grid Background="#F0F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#678EC2">
            <TextBlock Text="Cámaras del edificio" VerticalAlignment="Center" Margin="20,0,0,0"
                       Foreground="#1A2530" FontWeight="SemiBold"/>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="20">
            <ItemsControl x:Name="ListaCamaras">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#8AAADD" CornerRadius="10" Margin="0,0,0,15" Padding="15">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="{Binding Titulo}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                                    <TextBlock Text="IPv4:" FontSize="11" Margin="0,0,0,5"/>

                                    <!-- Campo IPv4 con placeholder -->
                                    <Border Background="White" CornerRadius="6" Height="30" Margin="0,0,0,10">
                                        <Grid>
                                            <TextBox Text="{Binding IP, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" VerticalContentAlignment="Center"
                                                     Padding="10,0" Background="Transparent"
                                                     x:Name="TxtIP"/>
                                            <!-- Placeholder IPv4 -->
                                            <TextBlock Text="Ej. 192.168.1.100"
                                                       VerticalAlignment="Center" Margin="10,0,30,0"
                                                       Foreground="Gray" FontSize="11"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IP}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,10,0" Foreground="Gray"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="IPv6 / Ruta de captura:" FontSize="11" Margin="0,0,0,5"/>

                                    <!-- Campo IPv6/Ruta con placeholder -->
                                    <Border Background="White" CornerRadius="6" Height="30" Margin="0,0,0,15">
                                        <Grid>
                                            <TextBox Text="{Binding Ruta, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" VerticalContentAlignment="Center"
                                                     Padding="10,0" Background="Transparent"
                                                     x:Name="TxtRuta"/>
                                            <!-- Placeholder IPv6 -->
                                            <TextBlock Text="Ej. 2001:db8::1 o rtsp://..."
                                                       VerticalAlignment="Center" Margin="10,0,30,0"
                                                       Foreground="Gray" FontSize="11"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Ruta}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,10,0" Foreground="Gray"/>
                                        </Grid>
                                    </Border>

                                    <Button Content="Actualizar" Tag="{Binding}"
                                            Click="BtnActualizar_Click"
                                            Width="120" HorizontalAlignment="Right"
                                            Background="#678EC2" Foreground="White">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- Botón estado conexión -->
                                <Button Content="{Binding TextoBotonConexion}" Tag="{Binding}"
                                        Click="BtnToggleConexion_Click"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Width="110" Height="25"
                                        Background="#678EC2" Foreground="#1A2530" BorderThickness="0">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>