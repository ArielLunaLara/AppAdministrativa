<Window x:Class="AppAdministrativa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Photo-Image Login"
        WindowState="Maximized" 
        WindowStartupLocation="CenterScreen">

    <Grid Background="#DCE4EF">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Photo-Image" FontSize="36" FontWeight="Bold"
                       Foreground="#39568C" HorizontalAlignment="Center"
                       Margin="0,0,0,40" FontFamily="Segoe UI"/>

            <TextBlock Text="Usuario" FontSize="12" FontWeight="SemiBold"
                       Foreground="#39568C" Margin="0,0,0,5"/>
            <Border Background="#B8CBE6" CornerRadius="6" Height="40" Margin="0,0,0,15">
                <TextBox x:Name="TxtUsuario" Background="Transparent" BorderThickness="0"
                         VerticalContentAlignment="Center" Padding="12,0"
                         Foreground="#4A4A4A" FontSize="13"/>
            </Border>

            <TextBlock Text="Contraseña" FontSize="12" FontWeight="SemiBold"
                       Foreground="#39568C" Margin="0,0,0,5"/>
            <Border Background="#B8CBE6" CornerRadius="6" Height="40" Margin="0,0,0,25">
                <!-- PasswordBox para ocultar caracteres -->
                <PasswordBox x:Name="TxtPassword" Background="Transparent" BorderThickness="0"
                             VerticalContentAlignment="Center" Padding="12,0"
                             Foreground="#4A4A4A" FontSize="13"
                             KeyDown="TxtPassword_KeyDown"/>
            </Border>

            <TextBlock x:Name="TxtError" Text="" Foreground="#C0392B"
                       FontSize="11" HorizontalAlignment="Center"
                       Margin="0,0,0,10" Visibility="Collapsed"/>

            <Button x:Name="BtnIniciarSesion" Click="BtnIniciarSesion_Click"
                    Height="40" BorderThickness="0"
                    Foreground="White" FontSize="14" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
                <Button.Background>
                    <SolidColorBrush Color="#3F5C8C"/>
                </Button.Background>
                <TextBlock Text="Iniciar Sesión" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

        </StackPanel>
    </Grid>
</Window>
