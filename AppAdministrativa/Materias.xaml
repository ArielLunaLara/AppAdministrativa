<Page x:Class="AppAdministrativa.Materias"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Materias">

    <Grid Background="#F0F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Grid Grid.Row="1" Margin="40,20,40,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--  Barra de búsqueda -->
            <Border Background="#C9D9F0" CornerRadius="6" Height="35" Width="400" HorizontalAlignment="Left" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Foreground="#4A4A4A" Margin="0,0,10,0"/>

                    <TextBox x:Name="txtBuscar"
                 Text="Buscar Materia..."
                 Background="Transparent"
                 BorderThickness="0"
                 VerticalAlignment="Center"
                 Width="350"
                 Foreground="Gray"
                 TextChanged="txtBuscar_TextChanged"
                 GotFocus="txtBuscar_GotFocus"
                 LostFocus="txtBuscar_LostFocus"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20" Panel.ZIndex="1">
                <Button Click="BtnAgregar_Click" Width="100" Height="35" Margin="0,0,15,0" BorderThickness="0" Foreground="White" Cursor="Hand">
                    <Button.Background>
                        <SolidColorBrush Color="#8AAADD"/>
                    </Button.Background>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="Agregar"/>
                </Button>
                <Button Click="BtnEditar_Click" Width="100" Height="35" Margin="0,0,15,0" BorderThickness="0" Foreground="White" Cursor="Hand">
                    <Button.Background>
                        <SolidColorBrush Color="#678EC2"/>
                    </Button.Background>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="Editar"/>
                </Button>
                <Button Click="BtnEliminar_Click" Width="100" Height="35" BorderThickness="0" Foreground="White" Cursor="Hand">
                    <Button.Background>
                        <SolidColorBrush Color="#3F5C8C"/>
                    </Button.Background>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock Text="Eliminar"/>
                </Button>
            </StackPanel>

            <DataGrid x:Name="TablaMaterias" Grid.Row="2" Background="#E2E9F4" RowBackground="#EAEFF5" AlternatingRowBackground="#D9E2EF" 
                      AutoGenerateColumns="False" HeadersVisibility="Column" GridLinesVisibility="All" 
                      BorderBrush="#3F5C8C" BorderThickness="1" RowHeight="35" Panel.ZIndex="1">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#678EC2"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="1*"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="3*"/>
                    <DataGridTextColumn Header="Compañías" Binding="{Binding Companias}" Width="2*"/>
                    <DataGridTextColumn Header="Ruta Temario" Binding="{Binding RutaTemario}" Width="3*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>